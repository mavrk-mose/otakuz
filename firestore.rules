rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/chatrooms/$(roomId));
    }

    function isRoomMember(roomId) {
      return signedIn()
        && room(roomId).data.members is list
        && room(roomId).data.members.hasAny([request.auth.uid]);
    }

    function isRoomOwner(roomId) {
      return signedIn() && room(roomId).data.createdBy == request.auth.uid;
    }

    function isJoiningSelf() {
      return signedIn()
        && resource.data.members is list
        && request.resource.data.members is list
        && !resource.data.members.hasAny([request.auth.uid])
        && request.resource.data.members.hasAny([request.auth.uid])
        && request.resource.data.members.hasAll(resource.data.members)
        && request.resource.data.members.size() == resource.data.members.size() + 1
        && request.resource.data.memberCount == request.resource.data.members.size()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['members', 'memberCount']);
    }

    match /chatrooms/{roomId} {
      // Signed-in users can discover a room before choosing to join it.
      allow get, list: if signedIn();

      allow create: if signedIn()
        && request.resource.data.keys().hasOnly([
          'title', 'createdBy', 'createdAt', 'members', 'memberCount'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.createdAt == request.time
        && request.resource.data.members == [request.auth.uid]
        && request.resource.data.memberCount == 1;

      allow update: if isJoiningSelf()
        || (isRoomOwner(roomId)
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.createdAt == resource.data.createdAt
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['title'])
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 80);

      allow delete: if isRoomOwner(roomId);

      match /messages/{messageId} {
        // Room members need to read one another's messages for group chat.
        // Only the authenticated author can create or mutate their messages.
        allow read: if isRoomMember(roomId);

        allow create: if isRoomMember(roomId)
          && request.resource.data.keys().hasOnly([
            'userId', 'username', 'message', 'type', 'timestamp',
            'createdAtClient', 'fileUrl', 'fileType', 'animeData'
          ])
          && request.resource.data.keys().hasAll([
            'userId', 'username', 'message', 'type', 'timestamp', 'createdAtClient'
          ])
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.username is string
          && request.resource.data.username.size() > 0
          && request.resource.data.username.size() <= 120
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 4000
          && request.resource.data.type in [
            'text', 'image', 'video', 'audio', 'file', 'anime_share'
          ]
          && request.resource.data.timestamp == request.time
          && request.resource.data.createdAtClient is int;

        allow update: if signedIn()
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['message', 'editedAt'])
          && request.resource.data.message is string
          && request.resource.data.message.size() <= 4000
          && request.resource.data.editedAt == request.time;

        allow delete: if signedIn() && resource.data.userId == request.auth.uid;
      }

      match /typing/{userId} {
        allow read: if isRoomMember(roomId);
        allow create, update: if isRoomMember(roomId)
          && request.auth.uid == userId
          && request.resource.data.userId == request.auth.uid;
        allow delete: if isRoomMember(roomId) && request.auth.uid == userId;
      }

      match /invites/{inviteId} {
        allow read: if isRoomOwner(roomId);
        allow create: if isRoomOwner(roomId)
          && request.resource.data.invitedBy == request.auth.uid;
        allow update, delete: if isRoomOwner(roomId);
      }
    }

    match /users/{userId}/{document=**} {
      allow read, write: if signedIn() && request.auth.uid == userId;
    }

    // Supports the existing collection-group bookmark lookup without exposing
    // another user's saved items.
    match /{path=**}/items/{itemId} {
      allow read: if signedIn() && resource.data.addedBy == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.timestamp == request.time;
      allow read, update, delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
